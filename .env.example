# 环境变量配置
# ⚠️ 不要提交到 Git！复制为 .env 后填入真实值

# ========== 阿里百炼 API ==========
# 申请地址：https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ========== 高德地图 API ==========
# 申请地址：https://console.amap.com/dev/index
# 需要服务：JavaScript API + Web 服务 API
VITE_AMAP_KEY=your_amap_key_here
VITE_AMAP_SECURITY_CODE=your_amap_security_code_here

# ========== Vercel 配置（部署时用）==========
# 申请地址：https://vercel.com/account/tokens
VERCEL_TOKEN=your_vercel_token_here
